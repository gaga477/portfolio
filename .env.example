# Example environment variables for local development and Render

# Backend port fallback for local dev
PORT=3001

# MongoDB connection string for local development
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio

# Resend API key for email delivery (https://resend.com)
# Works on all hosts including Render free tier (no SMTP port restrictions)
RESEND_API_KEY=re_your_api_key_here

# Your email address — where contact messages are delivered
EMAIL_USER=your-email@example.com

# Optional frontend URL used by CORS
CLIENT_URL=http://localhost:3000

# Frontend API base URL for local development (used by Vite)
VITE_API_URL=http://localhost:3001
